# ============================================================
#  Le Flutch — Configuration
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Base de données PostgreSQL ──
DATABASE_URL=postgresql://user:password@host:5432/flutch

# ── Pipedrive ──
PIPEDRIVE_API_TOKEN=colle_ta_cle_ici
BIENS_PIPELINE=Murs
BIENS_STAGE=Commercialisé
ACQUEREURS_PIPELINE=Acquéreurs
ACQUEREURS_STAGE=Matching commercialisé

# ── Serveur ──
PORT=3000
NODE_ENV=development

# Secret de session (OBLIGATOIRE en production — chaîne aléatoire ≥ 32 caractères)
SESSION_SECRET=flutch-secret-change-moi-2024

# Secret webhook Pipedrive (généré automatiquement si absent)
# WEBHOOK_SECRET=

# ── Intégrations (optionnel) ──
# Clef API Brevo (pour envoi SMS / email). Si vous n'avez pas de compte Brevo, voir instructions pour utiliser le mock local.
BREVO_API_KEY=
# URL de l'API Brevo; par défaut `https://api.brevo.com/v3`. Pour tests locaux sans compte Brevo, définissez `BREVO_API_URL=http://localhost:4001`.
BREVO_API_URL=
RINGOVER_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Auto-sync ──
# Intervalle auto-sync Pipedrive (minutes, 0 = désactivé)
AUTO_SYNC_MINUTES=60

# ── CORS (optionnel, CSV d'origines autorisées) ──
# CORS_ORIGIN=https://example.com

# ============================================================
#  Agent Worker — Configuration
#  (Utilisé par npm run worker:agent)
# ============================================================

# Connexion à l'API Flutch
FLUTCH_API_URL=http://localhost:3000
FLUTCH_EMAIL=agent-test@example.com
FLUTCH_PASSWORD=your-secure-password-here

# Comportement du worker - Gestion des cycles
MAX_SENDS_PER_CYCLE=20                    # Max acquéreurs à contacter par cycle
CYCLE_INTERVAL_MINUTES=30                 # Minutes entre les cycles
MAX_BIENS_PER_ACQUEREUR=3                 # Max biens à envoyer par acquéreur par cycle
RATE_LIMIT_MS=2500                        # Millisecondes d'attente entre envois d'acquéreurs

# Résilience API
API_CALL_MAX_RETRIES=3                    # Max tentatives pour les appels API
API_CALL_RETRY_DELAY_MS=1000              # Délai initial (ms) pour backoff exponentiel

# Fuseau horaire et heures d'activité
TIMEZONE=Europe/Paris
WORK_START_HOUR=9                         # Format 24h (ex: 9 = 9h du matin)
WORK_END_HOUR=19                          # Format 24h (ex: 19 = 19h du soir)

# Persistance
STATE_FILE_PATH=data/agent-state.json     # Chemin du fichier JSON d'état local

# Debug
# DEBUG=true                               # Décommenter pour logs verbeux
